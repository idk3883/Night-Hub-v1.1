-- Night Hub v1.1
-- Fixed Mobile Fly + Working Speed + Working Jump
-- Black & White Premium UI

local player = game.Players.LocalPlayer
local RunService = game:GetService("RunService")

local flying = false
local noclip = false
local speedValue = 16
local jumpValue = 50

local bodyVelocity
local bodyGyro

-- =====================
-- CHARACTER HANDLING
-- =====================

local function applyStats()
	local char = player.Character
	if not char then return end
	
	local hum = char:FindFirstChildOfClass("Humanoid")
	if hum then
		hum.UseJumpPower = true
		hum.WalkSpeed = speedValue
		hum.JumpPower = jumpValue
	end
end

player.CharacterAdded:Connect(function()
	task.wait(1)
	applyStats()
end)

-- =====================
-- FLY SYSTEM (Joystick Based)
-- =====================

local function startFly()
	local char = player.Character
	if not char then return end
	
	local hum = char:FindFirstChildOfClass("Humanoid")
	local root = char:FindFirstChild("HumanoidRootPart")
	if not hum or not root then return end
	
	hum:ChangeState(Enum.HumanoidStateType.Physics)
	
	bodyVelocity = Instance.new("BodyVelocity")
	bodyVelocity.MaxForce = Vector3.new(1,1,1) * 1e6
	bodyVelocity.Velocity = Vector3.zero
	bodyVelocity.Parent = root
	
	bodyGyro = Instance.new("BodyGyro")
	bodyGyro.MaxTorque = Vector3.new(1,1,1) * 1e6
	bodyGyro.CFrame = root.CFrame
	bodyGyro.Parent = root
	
	RunService:BindToRenderStep("FlyMove", 0, function()
		local moveDir = hum.MoveDirection
		bodyVelocity.Velocity = Vector3.new(
			moveDir.X * speedValue,
			0,
			moveDir.Z * speedValue
		)
		bodyGyro.CFrame = workspace.CurrentCamera.CFrame
	end)
end

local function stopFly()
	RunService:UnbindFromRenderStep("FlyMove")
	if bodyVelocity then bodyVelocity:Destroy() end
	if bodyGyro then bodyGyro:Destroy() end
end

-- =====================
-- NOCLIP
-- =====================

local function enableNoclip()
	RunService:BindToRenderStep("Noclip", 1, function()
		local char = player.Character
		if char then
			for _,v in pairs(char:GetDescendants()) do
				if v:IsA("BasePart") then
					v.CanCollide = false
				end
			end
		end
	end)
end

local function disableNoclip()
	RunService:UnbindFromRenderStep("Noclip")
end

-- =====================
-- TELEPORT
-- =====================

local function teleportTo(name)
	local target = game.Players:FindFirstChild(name)
	if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
		local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		if root then
			root.CFrame = target.Character.HumanoidRootPart.CFrame + Vector3.new(0,3,0)
		end
	end
end

